{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "npm: watch",
      "detail": "node esbuild.js --watch",
      "problemMatcher": [
        {
          "owner": "claude-io-esbuild",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "pattern": [
            {
              "regexp": "^\\s*([^\\s].+):(\\d+):(\\d+):\\s+(error|warning):\\s+(.+)$",
              "file": 1,
              "line": 2,
              "column": 3,
              "severity": 4,
              "message": 5
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^\\[claude-io\\] esbuild: build started$",
            "endsPattern": "^\\[claude-io\\] esbuild: build finished(?: with \\d+ error\\(s\\))?$"
          }
        }
      ]
    }
  ]
}
